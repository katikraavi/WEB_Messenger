# Copy to .env.oracle and fill values
# cp oracle.env.example .env.oracle

# Public URL where frontend is served
APP_BASE_URL=http://YOUR_ORACLE_PUBLIC_IP
FRONTEND_URL=http://YOUR_ORACLE_PUBLIC_IP

# Optional HTTPS domain (required for automatic Let's Encrypt via Caddy)
# Example: chat.yourdomain.com
DOMAIN=

# Frontend build target (must point to same public URL)
BACKEND_URL=http://YOUR_ORACLE_PUBLIC_IP

# Database (Neon recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_SSL=true

# Encryption (required, keep this secret)
ENCRYPTION_MASTER_KEY=replace-with-64-plus-random-characters

# Email (recommended on cloud: Resend API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Mobile Messenger <onboarding@resend.dev>

# Optional SMTP fallback (leave empty if using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Mobile Messenger
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Optional
VERBOSE_BACKEND_LOGS=false
ADMIN_DELETE_KEY=

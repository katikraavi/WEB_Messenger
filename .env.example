# Backend Configuration
# Copy this file to .env in the project root and customize for your environment.
# The real .env file is ignored by git and may contain local SMTP credentials.

# Database Configuration
DATABASE_URL=postgres://messenger_user:messenger_password@postgres:5432/messenger_db
DATABASE_SSL=false
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=messenger_db
DATABASE_USER=messenger_user
DATABASE_PASSWORD=messenger_password

# Production example for Neon:
# DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
# DATABASE_SSL=true
# DATABASE_HOST=<host>
# DATABASE_PORT=5432
# DATABASE_NAME=<database>
# DATABASE_USER=<user>
# DATABASE_PASSWORD=<password>

# Serverpod Configuration
SERVERPOD_ENV=development
SERVERPOD_PORT=8081

# Frontend Configuration
FRONTEND_BUILD_MODE=debug
FLUTTER_BUILD_NUMBER=1
FLUTTER_BUILD_NAME=1.0.0

# Application Configuration
APP_NAME=Mobile Messenger
APP_VERSION=1.0.0
APP_DEBUG=true

# SMTP Configuration
# Default local development route: MailHog capture at http://localhost:8025
# This is the safest default because it does not send to real inboxes.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@local.messenger
SMTP_FROM_NAME=Mobile Messenger
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# To use Gmail SMTP for real inbox delivery, replace the SMTP values above with:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM_EMAIL=youraddress@gmail.com
# SMTP_FROM_NAME=Mobile Messenger
# SMTP_USER=youraddress@gmail.com
# SMTP_PASSWORD=your_16_character_gmail_app_password
# SMTP_SECURE=false

# Notes:
# - Use a Gmail App Password, not your normal Gmail password.
# - Do not commit the real .env file.
# - Plain `docker compose up -d --build` will use whatever SMTP settings are in .env.

# Backend Configuration
# Copy this file to .env in the project root and customize for your environment

# Database Configuration
DATABASE_URL=postgres://messenger_user:messenger_password@postgres:5432/messenger_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=messenger_db
DATABASE_USER=messenger_user
DATABASE_PASSWORD=messenger_password

# Serverpod Configuration
SERVERPOD_ENV=development
SERVERPOD_PORT=8081

# Frontend Configuration
FRONTEND_BUILD_MODE=debug
FLUTTER_BUILD_NUMBER=1
FLUTTER_BUILD_NAME=1.0.0

# Application Configuration
APP_NAME=Mobile Messenger
APP_VERSION=1.0.0
APP_DEBUG=true

# SMTP / SendGrid Configuration
# Copy this file to .env in the project root and set real values there.
# SMTP_FROM_EMAIL must be verified in SendGrid.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=465
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Mobile Messenger
SMTP_USER=apikey
SMTP_PASSWORD=SG.replace_with_your_sendgrid_api_key
SMTP_SECURE=true
